 drivers/gpu/drm/bridge/sii902x.c | 905 ++++++++++++++++++-------------
 1 file changed, 531 insertions(+), 374 deletions(-)

diff --git a/drivers/gpu/drm/bridge/sii902x.c b/drivers/gpu/drm/bridge/sii902x.c
index 8a3fdccc665e..098decce5843 100644
--- a/drivers/gpu/drm/bridge/sii902x.c
+++ b/drivers/gpu/drm/bridge/sii902x.c
@@ -21,6 +21,7 @@
 #include <linux/regulator/consumer.h>
 #include <linux/clk.h>
 
+#include <drm/display/drm_hdmi_state_helper.h>
 #include <drm/drm_atomic_helper.h>
 #include <drm/drm_bridge.h>
 #include <drm/drm_drv.h>
@@ -180,8 +181,9 @@ struct sii902x {
 	struct gpio_desc *reset_gpio;
 	struct i2c_mux_core *i2cmux;
 	struct device_link *link;
-	unsigned int ctx_tpi;
 	unsigned int ctx_interrupt;
+	unsigned int ctx_audio_config;
+	bool d3_suspended;
 	u32 bus_width;
 
 	/*
@@ -193,13 +195,6 @@ struct sii902x {
 		struct platform_device *pdev;
 		struct clk *mclk;
 		u32 i2s_fifo_sequence[4];
-		bool active;
-		/* Audio register context for save/resume */
-		unsigned int ctx_i2s_input_config;
-		unsigned int ctx_audio_config_byte2;
-		unsigned int ctx_audio_config_byte3;
-		u8 ctx_i2s_stream_header[SII902X_TPI_I2S_STRM_HDR_SIZE];
-		u8 ctx_audio_infoframe[SII902X_TPI_MISC_INFOFRAME_SIZE];
 	} audio;
 };
 
@@ -331,17 +326,66 @@ static const struct drm_connector_helper_funcs sii902x_connector_helper_funcs =
 	.get_modes = sii902x_get_modes,
 };
 
+static int sii902x_set_power_state(struct sii902x *sii902x, unsigned int d_state)
+{
+	return regmap_update_bits(sii902x->regmap, SII902X_PWR_STATE_CTRL,
+				  SII902X_AVI_POWER_STATE_MSK,
+				  SII902X_AVI_POWER_STATE_D(d_state));
+}
+
+static unsigned int sii902x_clear_interrupts(struct sii902x *sii902x)
+{
+	unsigned int status;
+
+	regmap_read(sii902x->regmap, SII902X_INT_STATUS, &status);
+	regmap_write(sii902x->regmap, SII902X_INT_STATUS, status);
+	return status;
+}
+
+static int sii902x_audio_decode_l0(struct sii902x *sii902x)
+{
+	int ret;
+
+	ret = regmap_write(sii902x->regmap, SII902X_IND_SET_PAGE, 0x02);
+	if (ret)
+		return ret;
+
+	ret = regmap_write(sii902x->regmap, SII902X_IND_OFFSET, 0x24);
+	if (ret)
+		return ret;
+
+	return regmap_write(sii902x->regmap, SII902X_IND_VALUE, 0x02);
+}
+
 static void sii902x_bridge_atomic_disable(struct drm_bridge *bridge,
 					  struct drm_atomic_state *state)
 {
 	struct sii902x *sii902x = bridge_to_sii902x(bridge);
 
+	/* Save state before D3 Cold chip reset. */
+	regmap_read(sii902x->regmap, SII902X_INT_ENABLE, &sii902x->ctx_interrupt);
+	regmap_read(sii902x->regmap, SII902X_TPI_AUDIO_CONFIG_BYTE2_REG,
+		    &sii902x->ctx_audio_config);
+
 	mutex_lock(&sii902x->mutex);
 
 	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
 			   SII902X_SYS_CTRL_PWR_DWN,
 			   SII902X_SYS_CTRL_PWR_DWN);
 
+	/* D3 Cold entry */
+	if (sii902x->reset_gpio) {
+		sii902x_clear_interrupts(sii902x);
+		sii902x_reset(sii902x);
+		regmap_write(sii902x->regmap, SII902X_REG_TPI_RQB, 0x0);
+		regmap_write(sii902x->regmap, SII902X_INT_ENABLE,
+			     SII902X_HOTPLUG_EVENT);
+		sii902x_clear_interrupts(sii902x);
+
+		sii902x->d3_suspended = true;
+		sii902x_set_power_state(sii902x, 3);
+	}
+
 	mutex_unlock(&sii902x->mutex);
 }
 
@@ -350,36 +394,57 @@ static void sii902x_bridge_atomic_enable(struct drm_bridge *bridge,
 {
 	struct sii902x *sii902x = bridge_to_sii902x(bridge);
 	struct drm_connector *connector;
+	struct drm_connector_state *conn_state;
+	struct drm_crtc_state *crtc_state;
+	const struct drm_display_mode *adj;
 	u8 output_mode = SII902X_SYS_CTRL_OUTPUT_DVI;
+	u8 buf[10];
+	u16 pixel_clock_10kHz;
+
+	/* Full hardware init required after D3. */
+	if (sii902x->d3_suspended) {
+		int i;
+
+		sii902x->d3_suspended = false;
+		sii902x_reset(sii902x);
+		regmap_write(sii902x->regmap, SII902X_REG_TPI_RQB, 0x0);
+		regmap_write(sii902x->regmap, SII902X_INT_ENABLE,
+			     sii902x->ctx_interrupt);
+		sii902x_clear_interrupts(sii902x);
+
+		/* Restore audio hardware state lost on chip reset. */
+		if (sii902x->ctx_audio_config) {
+			for (i = 0; i < ARRAY_SIZE(sii902x->audio.i2s_fifo_sequence) &&
+				    sii902x->audio.i2s_fifo_sequence[i]; i++)
+				regmap_write(sii902x->regmap,
+					     SII902X_TPI_I2S_ENABLE_MAPPING_REG,
+					     sii902x->audio.i2s_fifo_sequence[i]);
+			sii902x_audio_decode_l0(sii902x);
+			regmap_write(sii902x->regmap,
+				     SII902X_TPI_AUDIO_CONFIG_BYTE2_REG,
+				     sii902x->ctx_audio_config);
+		}
+	}
 
 	connector = drm_atomic_get_new_connector_for_encoder(state, bridge->encoder);
-	if (connector && connector->display_info.is_hdmi)
-		output_mode = SII902X_SYS_CTRL_OUTPUT_HDMI;
+	if (!connector)
+		return;
 
-	mutex_lock(&sii902x->mutex);
+	conn_state = drm_atomic_get_new_connector_state(state, connector);
+	if (!conn_state)
+		return;
 
-	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
-			   SII902X_SYS_CTRL_OUTPUT_MODE, output_mode);
-	regmap_update_bits(sii902x->regmap, SII902X_PWR_STATE_CTRL,
-			   SII902X_AVI_POWER_STATE_MSK,
-			   SII902X_AVI_POWER_STATE_D(0));
-	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
-			   SII902X_SYS_CTRL_PWR_DWN, 0);
+	crtc_state = drm_atomic_get_new_crtc_state(state, conn_state->crtc);
+	if (!crtc_state)
+		return;
 
-	mutex_unlock(&sii902x->mutex);
-}
+	adj = &crtc_state->adjusted_mode;
 
-static void sii902x_bridge_mode_set(struct drm_bridge *bridge,
-				    const struct drm_display_mode *mode,
-				    const struct drm_display_mode *adj)
-{
-	struct sii902x *sii902x = bridge_to_sii902x(bridge);
-	struct regmap *regmap = sii902x->regmap;
-	u8 buf[HDMI_INFOFRAME_SIZE(AVI)];
-	struct hdmi_avi_infoframe frame;
-	u16 pixel_clock_10kHz = adj->clock / 10;
-	int ret;
+	if (connector->display_info.is_hdmi)
+		output_mode = SII902X_SYS_CTRL_OUTPUT_HDMI;
 
+	/* Write video timing to TPI registers */
+	pixel_clock_10kHz = adj->clock / 10;
 	buf[0] = pixel_clock_10kHz & 0xff;
 	buf[1] = pixel_clock_10kHz >> 8;
 	buf[2] = drm_mode_vrefresh(adj);
@@ -395,30 +460,49 @@ static void sii902x_bridge_mode_set(struct drm_bridge *bridge,
 
 	mutex_lock(&sii902x->mutex);
 
-	ret = regmap_bulk_write(regmap, SII902X_TPI_VIDEO_DATA, buf, 10);
-	if (ret)
-		goto out;
-
-	ret = drm_hdmi_avi_infoframe_from_display_mode(&frame,
-						       &sii902x->connector, adj);
-	if (ret < 0) {
-		DRM_ERROR("couldn't fill AVI infoframe\n");
-		goto out;
-	}
-
-	ret = hdmi_avi_infoframe_pack(&frame, buf, sizeof(buf));
-	if (ret < 0) {
-		DRM_ERROR("failed to pack AVI infoframe: %d\n", ret);
-		goto out;
-	}
+	/* Set output mode and enter D0 full-power */
+	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
+			   SII902X_SYS_CTRL_OUTPUT_MODE, output_mode);
+	sii902x_set_power_state(sii902x, 0);
 
-	/* Do not send the infoframe header, but keep the CRC field. */
-	regmap_bulk_write(regmap, SII902X_TPI_AVI_INFOFRAME,
-			  buf + HDMI_INFOFRAME_HEADER_SIZE - 1,
-			  HDMI_AVI_INFOFRAME_SIZE + 1);
+	regmap_bulk_write(sii902x->regmap, SII902X_TPI_VIDEO_DATA, buf, 10);
 
-out:
 	mutex_unlock(&sii902x->mutex);
+
+	/*
+	 * Populate the infoframe prior to enabling TMDS,
+	 * if connector is unavailable, pack frames manually
+	 */
+	if (connector->hdmi.funcs) {
+		drm_atomic_helper_connector_hdmi_update_infoframes(connector, state);
+
+		/* Start TMDS output */
+		mutex_lock(&sii902x->mutex);
+		regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
+				   SII902X_SYS_CTRL_PWR_DWN, 0);
+		mutex_unlock(&sii902x->mutex);
+	} else {
+		struct hdmi_avi_infoframe frame;
+		u8 avi_buf[HDMI_INFOFRAME_SIZE(AVI)];
+		int ret;
+
+		ret = drm_hdmi_avi_infoframe_from_display_mode(&frame,
+							       connector, adj);
+		if (!ret)
+			ret = hdmi_avi_infoframe_pack(&frame, avi_buf,
+						      sizeof(avi_buf));
+
+		/* Start TMDS output */
+		mutex_lock(&sii902x->mutex);
+		if (ret > 0)
+			regmap_bulk_write(sii902x->regmap,
+					  SII902X_TPI_AVI_INFOFRAME,
+					  avi_buf + HDMI_INFOFRAME_HEADER_SIZE - 1,
+					  HDMI_AVI_INFOFRAME_SIZE + 1);
+		regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
+				   SII902X_SYS_CTRL_PWR_DWN, 0);
+		mutex_unlock(&sii902x->mutex);
+	}
 }
 
 static int sii902x_bridge_attach(struct drm_bridge *bridge,
@@ -433,20 +517,36 @@ static int sii902x_bridge_attach(struct drm_bridge *bridge,
 
 	sii902x->link = device_link_add(drm->dev, dev, DL_FLAG_STATELESS);
 	if (!sii902x->link) {
-		dev_err(dev, "failed to create device link");
+		dev_err(dev, "failed to create device link\n");
 		return -EINVAL;
 	}
 
-	if (flags & DRM_BRIDGE_ATTACH_NO_CONNECTOR)
-		return drm_bridge_attach(encoder, sii902x->next_bridge,
-					 bridge, flags);
+	if (flags & DRM_BRIDGE_ATTACH_NO_CONNECTOR) {
+		/*
+		 * The framework creates its own audio codec via
+		 * DRM_BRIDGE_OP_HDMI_AUDIO; unregister the legacy one
+		 * to avoid duplicate audio devices.
+		 */
+		if (!PTR_ERR_OR_ZERO(sii902x->audio.pdev)) {
+			platform_device_unregister(sii902x->audio.pdev);
+			sii902x->audio.pdev = NULL;
+		}
+
+		if (sii902x->next_bridge) {
+			ret = drm_bridge_attach(encoder, sii902x->next_bridge,
+						bridge, flags);
+			if (ret)
+				goto err_bridge_attach;
+		}
+		return 0;
+	}
 
 	drm_connector_helper_add(&sii902x->connector,
 				 &sii902x_connector_helper_funcs);
 
 	if (!drm_core_check_feature(drm, DRIVER_ATOMIC)) {
 		dev_err(dev,
-			"sii902x driver is only compatible with DRM devices supporting atomic updates\n");
+			"legacy connector requires atomic modesetting support\n");
 		ret = -EOPNOTSUPP;
 		goto err_bridge_attach;
 	}
@@ -508,7 +608,6 @@ static u32 *sii902x_bridge_atomic_get_input_bus_fmts(struct drm_bridge *bridge,
 						     u32 output_fmt,
 						     unsigned int *num_input_fmts)
 {
-
 	struct sii902x *sii902x = bridge_to_sii902x(bridge);
 	u32 *input_fmts;
 
@@ -529,6 +628,7 @@ static u32 *sii902x_bridge_atomic_get_input_bus_fmts(struct drm_bridge *bridge,
 		input_fmts[0] = MEDIA_BUS_FMT_RGB888_1X24;
 		break;
 	default:
+		kfree(input_fmts);
 		return NULL;
 	}
 
@@ -569,35 +669,80 @@ sii902x_bridge_mode_valid(struct drm_bridge *bridge,
 	return MODE_OK;
 }
 
-static const struct drm_bridge_funcs sii902x_bridge_funcs = {
-	.attach = sii902x_bridge_attach,
-	.detach = sii902x_bridge_detach,
-	.mode_set = sii902x_bridge_mode_set,
-	.atomic_disable = sii902x_bridge_atomic_disable,
-	.atomic_enable = sii902x_bridge_atomic_enable,
-	.detect = sii902x_bridge_detect,
-	.edid_read = sii902x_bridge_edid_read,
-	.atomic_reset = drm_atomic_helper_bridge_reset,
-	.atomic_duplicate_state = drm_atomic_helper_bridge_duplicate_state,
-	.atomic_destroy_state = drm_atomic_helper_bridge_destroy_state,
-	.atomic_get_input_bus_fmts = sii902x_bridge_atomic_get_input_bus_fmts,
-	.atomic_check = sii902x_bridge_atomic_check,
-	.mode_valid = sii902x_bridge_mode_valid,
-};
+static enum drm_mode_status
+sii902x_bridge_hdmi_tmds_char_rate_valid(const struct drm_bridge *bridge,
+					 const struct drm_display_mode *mode,
