+{
+	return sii902x_bridge_mode_valid((struct drm_bridge *)bridge, NULL, mode);
+}
 
-static int sii902x_mute(struct sii902x *sii902x, bool mute)
+/* HDMI infoframe callbacks — framework packs, driver writes to hardware. */
+
+static int sii902x_bridge_hdmi_write_infoframe(struct drm_bridge *bridge,
+					       enum hdmi_infoframe_type type,
+					       const u8 *buffer, size_t len)
 {
-	struct device *dev = &sii902x->i2c->dev;
-	unsigned int val = mute ? SII902X_TPI_AUDIO_MUTE_ENABLE :
-		SII902X_TPI_AUDIO_MUTE_DISABLE;
+	struct sii902x *sii902x = bridge_to_sii902x(bridge);
 
-	dev_dbg(dev, "%s: %s\n", __func__, mute ? "Muted" : "Unmuted");
+	switch (type) {
+	case HDMI_INFOFRAME_TYPE_AVI:
+		/* Skip the infoframe header, keep the CRC field. */
+		mutex_lock(&sii902x->mutex);
+		regmap_bulk_write(sii902x->regmap, SII902X_TPI_AVI_INFOFRAME,
+				  buffer + HDMI_INFOFRAME_HEADER_SIZE - 1,
+				  min_t(size_t, len - HDMI_INFOFRAME_HEADER_SIZE + 1,
+					HDMI_AVI_INFOFRAME_SIZE + 1));
+		mutex_unlock(&sii902x->mutex);
+		break;
+	case HDMI_INFOFRAME_TYPE_AUDIO:
+		mutex_lock(&sii902x->mutex);
+		regmap_bulk_write(sii902x->regmap, SII902X_TPI_MISC_INFOFRAME_BASE,
+				  buffer, min_t(size_t, len,
+						SII902X_TPI_MISC_INFOFRAME_SIZE));
+		mutex_unlock(&sii902x->mutex);
+		break;
+	default:
+		/* VSIF and other types: no dedicated register space on SiI9022A */
+		break;
+	}
 
-	return regmap_update_bits(sii902x->regmap,
-				  SII902X_TPI_AUDIO_CONFIG_BYTE2_REG,
-				  SII902X_TPI_AUDIO_MUTE_ENABLE, val);
+	return 0;
+}
+
+static int sii902x_bridge_hdmi_clear_infoframe(struct drm_bridge *bridge,
+					       enum hdmi_infoframe_type type)
+{
+	struct sii902x *sii902x = bridge_to_sii902x(bridge);
+
+	switch (type) {
+	case HDMI_INFOFRAME_TYPE_AVI: {
+		u8 buf[HDMI_AVI_INFOFRAME_SIZE + 1] = {0};
+
+		mutex_lock(&sii902x->mutex);
+		regmap_bulk_write(sii902x->regmap, SII902X_TPI_AVI_INFOFRAME,
+				  buf, sizeof(buf));
+		mutex_unlock(&sii902x->mutex);
+		break;
+	}
+	case HDMI_INFOFRAME_TYPE_AUDIO: {
+		u8 buf[SII902X_TPI_MISC_INFOFRAME_SIZE] = {0};
+
+		mutex_lock(&sii902x->mutex);
+		regmap_bulk_write(sii902x->regmap, SII902X_TPI_MISC_INFOFRAME_BASE,
+				  buf, sizeof(buf));
+		mutex_unlock(&sii902x->mutex);
+		break;
+	}
+	default:
+		break;
+	}
+
+	return 0;
 }
 
+/* Shared audio helpers used by both legacy and modern audio paths. */
+
 static const int sii902x_mclk_div_table[] = {
 	128, 256, 384, 512, 768, 1024, 1152, 192 };
 
@@ -638,6 +783,56 @@ static const struct sii902x_sample_freq {
 	{ .freq = 192000,	.val = SII902X_TPI_AUDIO_FREQ_192KHZ },
 };
 
+/*
+ * Legacy hdmi-codec audio callbacks — used when the display controller
+ * does not use DRM_BRIDGE_ATTACH_NO_CONNECTOR and the bridge connector
+ * framework is not involved.
+ */
+
+static int sii902x_mute(struct sii902x *sii902x, bool mute)
+{
+	unsigned int val = mute ? SII902X_TPI_AUDIO_MUTE_ENABLE :
+		SII902X_TPI_AUDIO_MUTE_DISABLE;
+
+	return regmap_update_bits(sii902x->regmap,
+				  SII902X_TPI_AUDIO_CONFIG_BYTE2_REG,
+				  SII902X_TPI_AUDIO_MUTE_ENABLE, val);
+}
+
+static int sii902x_audio_get_eld(struct device *dev, void *data,
+				 uint8_t *buf, size_t len)
+{
+	struct sii902x *sii902x = dev_get_drvdata(dev);
+
+	mutex_lock(&sii902x->mutex);
+	memcpy(buf, sii902x->connector.eld,
+	       min(sizeof(sii902x->connector.eld), len));
+	mutex_unlock(&sii902x->mutex);
+
+	return 0;
+}
+
+static int sii902x_audio_get_dai_id(struct snd_soc_component *component,
+				    struct device_node *endpoint,
+				    void *data)
+{
+	struct of_endpoint of_ep;
+	int ret;
+
+	ret = of_graph_parse_endpoint(endpoint, &of_ep);
+	if (ret < 0)
+		return ret;
+
+	/*
+	 * HDMI sound should be located at reg = <3>
+	 * Return expected DAI index 0.
+	 */
+	if (of_ep.port == SII902X_AUDIO_PORT_INDEX)
+		return 0;
+
+	return -EINVAL;
+}
