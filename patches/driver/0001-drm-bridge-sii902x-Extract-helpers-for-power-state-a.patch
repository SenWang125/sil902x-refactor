From 79d42821befa0a656f5c52e01abbfeb0becc55b5 Mon Sep 17 00:00:00 2001
From: Sen Wang <sen@ti.com>
Date: Fri, 24 Apr 2026 16:27:54 -0500
Subject: [PATCH 1/4] drm/bridge: sii902x: Extract helpers for power state and
 interrupt handling

Factor out three operations that are used inline in the driver into
reusable helper functions:

- sii902x_set_power_state(): write the D-state to the power state
  control register (0x1E).
- sii902x_clear_interrupts(): read-and-write-back the interrupt status
  register (0x3D) to acknowledge pending interrupts.
- sii902x_audio_decode_l0(): indirect register write sequence to set
  audio FIFO decode level 0.

These helpers will be used by subsequent patches that add power
management and convert to the DRM_BRIDGE_OP_HDMI framework.

No functional change.

Signed-off-by: Sen Wang <s-wang12@ti.com>
---
 drivers/gpu/drm/bridge/sii902x.c | 55 ++++++++++++++++++++------------
 1 file changed, 35 insertions(+), 20 deletions(-)

diff --git a/drivers/gpu/drm/bridge/sii902x.c b/drivers/gpu/drm/bridge/sii902x.c
index 12497f5ce4ff..60d1e2d97c2c 100644
--- a/drivers/gpu/drm/bridge/sii902x.c
+++ b/drivers/gpu/drm/bridge/sii902x.c
@@ -320,6 +320,37 @@ static const struct drm_connector_helper_funcs sii902x_connector_helper_funcs =
 	.get_modes = sii902x_get_modes,
 };
 
+static int sii902x_set_power_state(struct sii902x *sii902x, unsigned int d_state)
+{
+	return regmap_update_bits(sii902x->regmap, SII902X_PWR_STATE_CTRL,
+				  SII902X_AVI_POWER_STATE_MSK,
+				  SII902X_AVI_POWER_STATE_D(d_state));
+}
+
+static unsigned int sii902x_clear_interrupts(struct sii902x *sii902x)
+{
+	unsigned int status;
+
+	regmap_read(sii902x->regmap, SII902X_INT_STATUS, &status);
+	regmap_write(sii902x->regmap, SII902X_INT_STATUS, status);
+	return status;
+}
+
+static int sii902x_audio_decode_l0(struct sii902x *sii902x)
+{
+	int ret;
+
+	ret = regmap_write(sii902x->regmap, SII902X_IND_SET_PAGE, 0x02);
+	if (ret)
+		return ret;
+
+	ret = regmap_write(sii902x->regmap, SII902X_IND_OFFSET, 0x24);
+	if (ret)
+		return ret;
+
+	return regmap_write(sii902x->regmap, SII902X_IND_VALUE, 0x02);
+}
+
 static void sii902x_bridge_atomic_disable(struct drm_bridge *bridge,
 					  struct drm_atomic_state *state)
 {
@@ -349,9 +380,7 @@ static void sii902x_bridge_atomic_enable(struct drm_bridge *bridge,
 
 	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
 			   SII902X_SYS_CTRL_OUTPUT_MODE, output_mode);
-	regmap_update_bits(sii902x->regmap, SII902X_PWR_STATE_CTRL,
-			   SII902X_AVI_POWER_STATE_MSK,
-			   SII902X_AVI_POWER_STATE_D(0));
+	sii902x_set_power_state(sii902x, 0);
 	regmap_update_bits(sii902x->regmap, SII902X_SYS_CTRL_DATA,
 			   SII902X_SYS_CTRL_PWR_DWN, 0);
 
@@ -742,16 +771,7 @@ static int sii902x_audio_hw_params(struct device *dev, void *data,
 	if (ret)
 		goto out;
 
-	/* Decode Level 0 Packets */
-	ret = regmap_write(sii902x->regmap, SII902X_IND_SET_PAGE, 0x02);
-	if (ret)
-		goto out;
-
-	ret = regmap_write(sii902x->regmap, SII902X_IND_OFFSET, 0x24);
-	if (ret)
-		goto out;
-
-	ret = regmap_write(sii902x->regmap, SII902X_IND_VALUE, 0x02);
+	ret = sii902x_audio_decode_l0(sii902x);
 	if (ret)
 		goto out;
 
@@ -932,10 +952,7 @@ static irqreturn_t sii902x_interrupt(int irq, void *data)
 	unsigned int status = 0;
 
 	mutex_lock(&sii902x->mutex);
-
-	regmap_read(sii902x->regmap, SII902X_INT_STATUS, &status);
-	regmap_write(sii902x->regmap, SII902X_INT_STATUS, status);
-
+	status = sii902x_clear_interrupts(sii902x);
 	mutex_unlock(&sii902x->mutex);
 
 	if ((status & SII902X_HOTPLUG_EVENT) && sii902x->bridge.dev) {
@@ -1072,7 +1089,6 @@ static const struct drm_bridge_timings default_sii902x_timings = {
 static int sii902x_init(struct sii902x *sii902x)
 {
 	struct device *dev = &sii902x->i2c->dev;
-	unsigned int status = 0;
 	u8 chipid[4];
 	int ret;
 
@@ -1096,8 +1112,7 @@ static int sii902x_init(struct sii902x *sii902x)
 	}
 
 	/* Clear all pending interrupts */
-	regmap_read(sii902x->regmap, SII902X_INT_STATUS, &status);
-	regmap_write(sii902x->regmap, SII902X_INT_STATUS, status);
+	sii902x_clear_interrupts(sii902x);
 
 	if (sii902x->i2c->irq > 0) {
 		regmap_write(sii902x->regmap, SII902X_INT_ENABLE,
